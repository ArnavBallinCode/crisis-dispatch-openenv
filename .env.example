# Local app server port
PORT=7860

# -----------------------------
# LLM provider configuration
# -----------------------------
# This project uses the OpenAI client, but supports OpenAI-compatible providers.
# You can use either OPENAI_* variables or generic API_* variables.

# Option A: OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini

# Option B: Groq (OpenAI-compatible endpoint)
# API_KEY=
# API_BASE_URL=https://api.groq.com/openai/v1
# MODEL_NAME=llama-3.1-8b-instant

# Optional metadata helper
HF_SPACE_ID=blackmamba2408/Crisis-Dispatch-OpenEnv

# Optional for CLI-based Space upload/push automation
HF_TOKEN=
